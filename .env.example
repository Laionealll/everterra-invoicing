# ─────────────────────────────────────────────────────────────
# Everterra Invoicing — environment variables
# Copy to `.env` for local dev, or set these in the Railway dashboard
# (Settings → Variables). Never commit real secrets.
# ─────────────────────────────────────────────────────────────

# Required — Postgres connection string.
# • Railway Postgres plugin injects this automatically (reference it as ${{ Postgres.DATABASE_URL }}).
# • Neon: copy the connection string and keep ?sslmode=require at the end.
DATABASE_URL=postgresql://user:password@host:5432/everterra

# Required — random secret, at least 32 characters.
# Generate one with:  openssl rand -base64 32
BETTER_AUTH_SECRET=

# Required in production — the public URL of the app, no trailing slash.
# e.g. https://your-app.up.railway.app  (or your custom domain)
# On Railway, RAILWAY_PUBLIC_DOMAIN is injected automatically and used as a fallback,
# but setting BETTER_AUTH_URL explicitly is the most reliable.
BETTER_AUTH_URL=

# Optional — transactional email via Resend. If either is missing, emails
# (invoice send, password reset) are logged to the server console instead of sent.
RESEND_API_KEY=
EMAIL_FROM=
